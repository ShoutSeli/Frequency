# ============================================
# UNIVERSAL WATCH HUB — environment variables
# Copy this file to apps/api/.env and fill in values
# ============================================

# --- Server ---
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database (Postgres) ---
# Local dev via docker-compose (see docker-compose.yml) or use a free hosted Postgres (Neon, Supabase)
DATABASE_URL="postgresql://uwh:uwh_password@localhost:5432/universal_watch_hub?schema=public"

# --- Redis (caching external API responses) ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET="replace_with_a_long_random_string"
JWT_EXPIRES_IN="7d"

# --- External data providers (all have free tiers) ---
# TMDB: https://www.themoviedb.org/settings/api  (movies, TV, anime metadata + watch providers)
TMDB_API_KEY=""
# TheSportsDB: https://www.thesportsdb.com/api.php (free tier key = "3")
SPORTSDB_API_KEY="3"
# Radio-Browser has no key required: https://api.radio-browser.info
# Spotify (for music embeds / search) https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# --- Payments (optional, for premium tier) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_PREMIUM=""
